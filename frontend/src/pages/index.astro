---
import { apiClient } from "../api/client";
import type { paths } from "../api/schema";
import { UserSummaryCard } from "@/components/user-summary-card";
import "@/styles/globals.css";

type UserProfile =
    paths["/users/{id}"]["get"]["responses"][200]["content"]["application/json"];

let user: UserProfile | null = null;
let errorMessage = "";

try {
    const response = await apiClient.GET("/users/{id}", {
        params: {
            path: {
                id: "usr_9988",
            },
        },
    });

    if (response.error) {
        errorMessage = "The API returned an error response.";
    } else {
        user = response.data ?? null;
    }
} catch (error) {
    errorMessage =
        error instanceof Error ? error.message : "Unable to reach the backend.";
}
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Magic Bullet</title>
    </head>
    <body class="dark">
        <main class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-6 py-12 md:px-10">
            <div class="grid w-full gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
                <UserSummaryCard client:load user={user} errorMessage={errorMessage} />

                <aside class="space-y-5 rounded-[28px] border border-border bg-card p-6">
                    <p class="text-xs font-medium uppercase tracking-[0.3em] text-muted-foreground">
                        Frontend stack
                    </p>
                    <div class="space-y-3 text-sm text-muted-foreground">
                        <p>Tailwind CSS v4 configurado via plugin oficial do Vite no Astro.</p>
                        <p>React pronto para islands e componentes client-side.</p>
                        <p>shadcn/ui preparado com `components.json`, aliases e utilitario `cn`.</p>
                    </div>
                    <div class="grid gap-3 text-sm text-foreground">
                        <div class="rounded-2xl border border-border bg-secondary px-4 py-3">`@/components/ui`</div>
                        <div class="rounded-2xl border border-border bg-secondary px-4 py-3">`@/lib/utils`</div>
                        <div class="rounded-2xl border border-border bg-secondary px-4 py-3">`src/styles/globals.css`</div>
                    </div>
                </aside>
            </div>
        </main>
    </body>
</html>
